# SdkWork News - PostgreSQL Development Environment Template
# Copy this file to .env and adjust values for your local setup.

# Database engine: sqlite or postgresql
SDKWORK_NEWS_DATABASE_ENGINE=postgresql

# PostgreSQL connection
SDKWORK_NEWS_DATABASE_HOST=localhost
SDKWORK_NEWS_DATABASE_PORT=5432
SDKWORK_NEWS_DATABASE_NAME=sdkwork_news_dev
SDKWORK_NEWS_DATABASE_USERNAME=sdkwork_news_dev
SDKWORK_NEWS_DATABASE_PASSWORD=your_password_here
SDKWORK_NEWS_DATABASE_SSL_MODE=disable
SDKWORK_NEWS_DATABASE_MAX_CONNECTIONS=10

# Admin connection (for database initialization)
SDKWORK_NEWS_DATABASE_ADMIN_USERNAME=postgres
SDKWORK_NEWS_DATABASE_ADMIN_PASSWORD=your_admin_password_here

# Deployment mode: server or desktop
SDKWORK_NEWS_DEPLOYMENT_MODE=server
